{
  "name": "@crm/reminder",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "esbuild src/main.ts --bundle --platform=node --format=cjs --target=node22 --outfile=dist/main.cjs",
    "start": "node dist/main.cjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@crm/shared": "0.1.0",
    "dotenv": "^16.4.7",
    "telegraf": "^4.16.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "esbuild": "^0.27.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}

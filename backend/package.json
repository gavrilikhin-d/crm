{
  "name": "@crm/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "esbuild src/server.ts --bundle --platform=node --format=cjs --target=node22 --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "seed": "tsx src/seed.ts",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "migrate:json": "tsx src/migrate-json.ts",
    "migrate:legacy-account": "tsx src/migrate-legacy-account.ts",
    "migrate:multitenancy": "tsx src/migrate-multitenancy.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test --preload ./src/test/preload.ts src",
    "test:unit": "bun test src/store-logic.test.ts",
    "test:integration": "bun test --preload ./src/test/preload.ts src/lesson-lifecycle.integration.test.ts"
  },
  "dependencies": {
    "@crm/shared": "0.1.0",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.45.2",
    "googleapis": "^173.0.0",
    "jose": "^6.0.11",
    "nanoid": "^5.0.9",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^22.10.5",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.27.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}

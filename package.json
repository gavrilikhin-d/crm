{
  "name": "vocal-teacher-crm",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "shared",
    "backend",
    "frontend",
    "bot",
    "reminder"
  ],
  "scripts": {
    "dev": "npm --workspace frontend run dev",
    "dev:frontend": "npm --workspace frontend run dev",
    "dev:backend": "npm --workspace backend run dev",
    "dev:bot": "npm --workspace bot run dev",
    "dev:reminder": "npm --workspace reminder run dev",
    "dev:reminders": "npm --workspace reminder run dev",
    "start": "npm --workspace frontend run start",
    "start:frontend": "npm --workspace frontend run start",
    "start:backend": "npm --workspace backend run start",
    "start:bot": "npm --workspace bot run start",
    "start:reminder": "npm --workspace reminder run start",
    "start:reminders": "npm --workspace reminder run start",
    "build": "npm --workspaces --if-present run build",
    "typecheck": "npm --workspaces --if-present run typecheck",
    "seed": "npm --workspace backend run seed"
  }
}

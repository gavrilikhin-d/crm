{
  "name": "vocal-teacher-crm",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.2.10",
  "workspaces": [
    "shared",
    "backend",
    "frontend",
    "bot",
    "reminder"
  ],
  "scripts": {
    "check-env": "bun scripts/check-env.ts",
    "dev": "bun --filter @crm/frontend dev",
    "predev:all": "bun scripts/check-env.ts dev",
    "dev:all": "set -a; [ ! -f .env ] || . ./.env; set +a; PORT=4000 bun run dev:backend & PORT=3000 bun run dev:frontend & bun run dev:bot & PORT=4001 bun run dev:reminder & wait",
    "predev:frontend": "bun scripts/check-env.ts frontend",
    "dev:frontend": "bun --filter @crm/frontend dev",
    "predev:backend": "bun scripts/check-env.ts backend",
    "dev:backend": "PORT=4000 bun --filter @crm/backend dev",
    "predev:bot": "bun scripts/check-env.ts bot",
    "dev:bot": "bun --filter @crm/bot dev",
    "predev:reminder": "bun scripts/check-env.ts reminder",
    "dev:reminder": "bun --filter @crm/reminder dev",
    "dev:reminders": "bun --filter @crm/reminder dev",
    "start": "bun --filter @crm/frontend start",
    "start:frontend": "bun --filter @crm/frontend start",
    "start:backend": "bun --filter @crm/backend start",
    "start:bot": "bun --filter @crm/bot start",
    "start:reminder": "bun --filter @crm/reminder start",
    "start:reminders": "bun --filter @crm/reminder start",
    "build": "bun --filter '*' build",
    "typecheck": "bun --filter '*' typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "bun --filter @crm/shared test && bun --filter @crm/bot test && bun --filter @crm/reminder test && bun --filter @crm/backend test",
    "seed": "cd backend && bun run seed",
    "db:push": "cd backend && bun run db:push",
    "observability:up": "docker compose -f docker-compose.observability.yml up -d",
    "observability:down": "docker compose -f docker-compose.observability.yml down",
    "prod:build": "docker compose -f docker-compose.prod.yml build",
    "prod:migrate": "docker compose -f docker-compose.prod.yml run --rm migrate",
    "prod:up": "docker compose -f docker-compose.prod.yml up -d",
    "prod:down": "docker compose -f docker-compose.prod.yml down",
    "migrate:multitenancy": "cd backend && bun run migrate:multitenancy",
    "migrate:json": "cd backend && bun run migrate:json"
  },
  "dependencies": {
    "googleapis": "^173.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.2.9",
    "globals": "^17.7.0",
    "typescript-eslint": "^8.62.1"
  }
}

PORT=3000
APP_BASE_URL=http://localhost:3000
# Timezone for Google Calendar events (IANA name)
APP_TIMEZONE=Europe/Minsk
# Used by Next.js rewrites and auth sync — must match backend listen port (4000 in dev)
BACKEND_INTERNAL_URL=http://localhost:4000
REMINDER_INTERNAL_URL=http://localhost:4001
DATABASE_URL=postgres://crm:crm@localhost:5432/crm

# Production Docker (docker-compose.prod.yml)
POSTGRES_USER=crm
POSTGRES_PASSWORD=
DOMAIN=vocalcrm.site
ACME_EMAIL=you@example.com
HTTP_PORT=80
HTTPS_PORT=443

# ECR image registry prefix (required for prod deploy). Host + namespace:
# CRM_IMAGE_REGISTRY=982081063376.dkr.ecr.eu-central-1.amazonaws.com/gavrilikhin
# Images: .../gavrilikhin/crm-backend:<sha>, crm-frontend, crm-bot, crm-reminder, crm-migrate
# CRM_IMAGE_TAG is set by CI on each deploy; for local builds use local + dev
CRM_IMAGE_REGISTRY=local
CRM_IMAGE_TAG=dev

# Separate DB for backend integration tests (`bun test`). Never point tests at production.
TEST_DATABASE_URL=postgres://crm:crm@localhost:5432/crm_test

# Log level for bot/reminder services: debug | info | warn | error
LOG_LEVEL=debug

# Optional. Push JSON logs to local Loki when running services with `bun dev:all`.
LOKI_PUSH_URL=http://127.0.0.1:3100/loki/api/v1/push

# Sentry (errors + logs). Works alongside Loki/Grafana.
# Next.js client DSN (public):
NEXT_PUBLIC_SENTRY_DSN=
# Optional. Browser websocket origin for snapshot updates. Defaults to ws://localhost:4000 in local dev
# and same-origin /api/ws/snapshot in production.
NEXT_PUBLIC_BACKEND_WS_URL=
# Server-side DSN for Next.js:
SENTRY_DSN=
# Backend API — separate Sentry project (Settings → Client Keys (DSN)):
BACKEND_SENTRY_DSN=
# Telegram bot — separate Sentry project:
BOT_SENTRY_DSN=
# Reminder service — separate Sentry project:
REMINDER_SENTRY_DSN=
# Source map upload on `next build` (create at sentry.io → Settings → Auth Tokens):
SENTRY_AUTH_TOKEN=
SENTRY_ORG=gavrilikhin-daniil
SENTRY_PROJECT=javascript-nextjs
BACKEND_SENTRY_PROJECT=backend
BOT_SENTRY_PROJECT=bot
REMINDER_SENTRY_PROJECT=reminder
# Usually set by CI to the deployed git SHA:
SENTRY_RELEASE=
# Optional override for Sentry environment tag (defaults to NODE_ENV):
SENTRY_ENVIRONMENT=

# Self-hosted Grafana (docker-compose.observability.yml). Change in production.
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_ROOT_URL=http://localhost:3030

# Auth (Google OAuth + JWT)
# Generate with openssl rand -base64 32
AUTH_SECRET=
AUTH_SYNC_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_URL=http://localhost:3000

# E2E auth (local Dex OIDC provider; start with `docker compose --profile e2e up -d oidc`)
E2E_AUTH=
NEXT_PUBLIC_E2E_AUTH=
E2E_BACKEND_URL=http://localhost:4100
PLAYWRIGHT_BASE_URL=http://localhost:3100
E2E_POSTGRES_PORT=55432
E2E_DATABASE_URL=postgres://crm:crm@localhost:55432/crm_e2e
AUTH_E2E_OIDC_ISSUER=http://localhost:5556/dex
AUTH_E2E_OIDC_ID=crm-e2e
AUTH_E2E_OIDC_SECRET=crm-e2e-secret

# Protect bot/reminder internal API routes
INTERNAL_API_TOKEN=

# Optional. Legacy JSON import path for `bun run migrate:json`.
DATA_FILE_PATH=backend/data/db.json

# Production Telegram bot. If empty, the web app works and Telegram sending is skipped.
TELEGRAM_BOT_TOKEN=
# Required in production when TELEGRAM_BOT_TOKEN is set. Use the public HTTPS ingress origin.
TELEGRAM_WEBHOOK_BASE_URL=https://vocalcrm.site
# Required in production when TELEGRAM_BOT_TOKEN is set. Generate a URL-safe random value.
TELEGRAM_WEBHOOK_SECRET=

# Local development Telegram bot. Create a separate test bot in BotFather.
# When set outside NODE_ENV=production, this overrides TELEGRAM_BOT_TOKEN for bot and reminder services.
TELEGRAM_DEV_BOT_TOKEN=
# Required when TELEGRAM_DEV_BOT_TOKEN is set. Point this at a public HTTPS tunnel to local BOT_PORT.
TELEGRAM_DEV_WEBHOOK_BASE_URL=
# Required when TELEGRAM_DEV_BOT_TOKEN is set. Generate a URL-safe random value.
TELEGRAM_DEV_WEBHOOK_SECRET=
BOT_PORT=4002

# Reminder lead times in minutes before the lesson.
LESSON_REMINDER_MINUTES=1440,120

# Telegram bot username used by frontend-generated connect links.
# In local development, set this to your test bot username when TELEGRAM_DEV_BOT_TOKEN is set.
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=VocalLessonBot

# Chromatic project token for storybook deployment
CHROMATIC_PROJECT_TOKEN=
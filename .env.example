PORT=3000
APP_BASE_URL=http://localhost:3000
# Timezone for Google Calendar events (IANA name)
APP_TIMEZONE=Europe/Minsk
# Used by Next.js rewrites and auth sync — must match backend listen port (4000 in dev)
BACKEND_INTERNAL_URL=http://localhost:4000
REMINDER_INTERNAL_URL=http://localhost:4001
DATABASE_URL=postgres://crm:crm@localhost:5432/crm

# Production Docker (docker-compose.prod.yml)
POSTGRES_USER=crm
POSTGRES_PASSWORD=
DOMAIN=crm.example.com
ACME_EMAIL=you@example.com
HTTP_PORT=80
HTTPS_PORT=443

# Separate DB for backend integration tests (`bun test`). Never point tests at production.
TEST_DATABASE_URL=postgres://crm:crm@localhost:5432/crm_test

# Log level for bot/reminder services: debug | info | warn | error
LOG_LEVEL=debug

# Optional. Push JSON logs to local Loki when running services with `bun dev:all`.
LOKI_PUSH_URL=http://127.0.0.1:3100/loki/api/v1/push

# Sentry (errors + logs). Works alongside Loki/Grafana.
# Next.js client DSN (public):
NEXT_PUBLIC_SENTRY_DSN=
# Server-side DSN for Next.js:
SENTRY_DSN=
# Backend API — separate Sentry project (Settings → Client Keys (DSN)):
BACKEND_SENTRY_DSN=
# Telegram bot — separate Sentry project:
BOT_SENTRY_DSN=
# Reminder service — separate Sentry project:
REMINDER_SENTRY_DSN=
# Source map upload on `next build` (create at sentry.io → Settings → Auth Tokens):
SENTRY_AUTH_TOKEN=
SENTRY_ORG=gavrilikhin-daniil
SENTRY_PROJECT=javascript-nextjs
# Optional override for Sentry environment tag (defaults to NODE_ENV):
SENTRY_ENVIRONMENT=

# Self-hosted Grafana (docker-compose.observability.yml). Change in production.
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_ROOT_URL=http://localhost:3030

# Auth (Google OAuth + JWT)
# Generate with openssl rand -base64 32
AUTH_SECRET=
AUTH_SYNC_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_URL=http://localhost:3000

# Protect bot/reminder internal API routes
INTERNAL_API_TOKEN=

# Optional. Legacy JSON import path for `bun run migrate:json`.
DATA_FILE_PATH=backend/data/db.json

# Optional. If empty, the web app works and Telegram sending is skipped.
TELEGRAM_BOT_TOKEN=

# Reminder lead times in minutes before the lesson.
LESSON_REMINDER_MINUTES=1440,120

# Telegram bot username.
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=VocalLessonBot
